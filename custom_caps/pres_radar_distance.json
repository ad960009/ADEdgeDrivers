{
	"id": "voicewatch56866.radarDistance",
	"version": 1,
	"detailView": [
		{
			"label": "Current Distance",
			"displayType": "state",
			"state": {
				"label": "{{distance.value}} {{distance.unit}}"
			}
		},
		{
			"label": "Detection Switch",
			"displayType": "list",
			"list": {
				"command": {
					"name": "setDistanceSwitch",
					"alternatives": [
						{
							"key": "on",
							"value": "ON",
							"type": "active"
						},
						{
							"key": "off",
							"value": "OFF",
							"type": "inactive"
						}
					]
				},
				"state": {
					"value": "distanceSwitch.value",
					"alternatives": [
						{
							"key": "on",
							"value": "ON",
							"type": "active"
						},
						{
							"key": "off",
							"value": "OFF",
							"type": "inactive"
						}
					]
				}
			}
		},
		{
			"label": "Min Detection Range",
			"displayType": "slider",
			"slider": {
				"command": "setDetectionDistanceMin",
				"value": "detectionDistanceMin.value",
				"step": 0.75,
				"range": [
					0,
					8.25
				]
			}
		},
		{
			"label": "Max Detection Range",
			"displayType": "slider",
			"slider": {
				"command": "setDetectionDistanceMax",
				"value": "detectionDistanceMax.value",
				"step": 0.75,
				"range": [
					0.75,
					9
				]
			}
		},
		{
			"label": "Move Sensitivity",
			"displayType": "stepper",
			"stepper": {
				"command": {
					"name": "setMoveSensitivity"
				},
				"value": "moveSensitivity.value",
				"step": 1,
				"range": [
					1,
					10
				]
			}
		},
		{
			"label": "Presence Sensitivity",
			"displayType": "stepper",
			"stepper": {
				"command": {
					"name": "setPresenceSensitivity"
				},
				"value": "presenceSensitivity.value",
				"step": 1,
				"range": [
					1,
					10
				]
			}
		},
		{
			"label": "Presence Timeout (sec)",
			"displayType": "numberField",
			"numberField": {
				"command": "setPresenceTimeout",
				"value": "presenceTimeout.value",
				"range": [
					1,
					15000
				]
			}
		}
	],
	"automation": {
		"conditions": [
			{
				"label": "Current Distance",
				"displayType": "numberField",
				"numberField": {
					"value": "distance.value",
					"unit": "distance.unit"
				}
			}
		],
		"actions": [
			{
				"label": "Detection Switch",
				"displayType": "list",
				"list": {
					"alternatives": [
						{
							"key": "on",
							"value": "ON",
							"type": "active"
						},
						{
							"key": "off",
							"value": "OFF",
							"type": "inactive"
						}
					]
				}
			}
		]
	}
}